# Only analyze and report issues found inside cpplib/src
HeaderFilterRegex: '.*src/.*'
Checks: >
  -*, bugprone-*, misc-*, cert-*, performance-*, modernize-*, -modernize-use-trailing-return-type, readability-*, -readability-braces-around-statements, -readability-implicit-bool-conversion, -readability-redundant-declaration, -google-readability-todo, -google-readability-namespace-comments, -llvm-header-guard, -readability-function-cognitive-complexity

CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  # Enforces CamelCase for all functions and methods (e.g., MyFunction)
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  # Enforces snake_case for local variables and parameters (e.g., my_variable)
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.GlobalConstantCase
    value: UPPER_CASE
  # Class Member Variables (snake_case, with optional trailing underscore for private members)
  - key: readability-identifier-naming.MemberCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: _
